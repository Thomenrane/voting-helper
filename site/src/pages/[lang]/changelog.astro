---
/**
 * Public changelog page (#26) — rendered at build time from the committed
 * structured changelog (data/src/changelog.ts), newest first. Each entry:
 * what changed, when, and a link to the public proof.
 */
import type { GetStaticPaths, InferGetStaticParamsType } from 'astro';
import { CHANGELOG } from '@voting-helper/data';
import { changelogDetail, changelogTitle } from '../../i18n/bilingual.ts';
import { LOCALES } from '../../i18n/locales.ts';
import { TRANSPARENCY } from '../../i18n/transparency.ts';
import TransparencyPage from '../../layouts/TransparencyPage.astro';
import { formatDateBE } from '../../lib/results/results-presentation.ts';
import { sortChangelog } from '../../lib/transparency/changelog-view.ts';

export const getStaticPaths = (() =>
  LOCALES.map((lang) => ({ params: { lang } }))) satisfies GetStaticPaths;

const { lang } = Astro.params as InferGetStaticParamsType<typeof getStaticPaths>;
const c = TRANSPARENCY[lang].changelog;

const entries = sortChangelog(CHANGELOG);
---

<TransparencyPage
  lang={lang}
  title={c.pageTitle}
  description={c.metaDescription}
  heading={c.heading}
  intro={c.intro}
>
  {entries.length === 0 ? (
    <p>{c.emptyNotice}</p>
  ) : (
    <ol class="entries" reversed>
      {entries.map((entry) => (
        <li class="entry">
          <p class="entry-head">
            <time class="entry-date" datetime={entry.date}>{formatDateBE(entry.date)}</time>
            <span class="entry-kind">{c.kindLabels[entry.kind]}</span>
          </p>
          <h2 class="entry-title">{changelogTitle(entry, lang)}</h2>
          <p class="entry-detail">
            {changelogDetail(entry, lang)}{' '}
            <a href={entry.url_preuve} rel="noopener">{c.proofLinkLabel}</a>
          </p>
        </li>
      ))}
    </ol>
  )}
</TransparencyPage>

<style>
  .entries {
    list-style: none;
    margin: 1.25rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .entry {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 0.625rem;
    padding: 0.875rem 1rem;
  }

  .entry-head {
    margin: 0;
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.375rem 0.625rem;
  }

  .entry-date {
    font-size: 0.8125rem;
    color: var(--ink-soft);
    font-variant-numeric: tabular-nums;
  }

  .entry-kind {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--accent-deep);
    background: var(--accent-wash);
    border-radius: 0.375rem;
    padding: 0.125rem 0.5rem;
  }

  /* Entry titles are list items, not page sections — override the shared
     prose h2 treatment from TransparencyPage. */
  .entry .entry-title {
    margin: 0.375rem 0 0;
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 1.0625rem;
    font-weight: 500;
    letter-spacing: -0.01em;
  }

  .entry .entry-detail {
    margin: 0.25rem 0 0;
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--ink-soft);
  }

  .entry-detail a {
    color: var(--accent-deep);
  }
</style>
