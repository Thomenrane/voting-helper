---
import TestWizard from '../../components/TestWizard.astro';
import { UI } from '../../i18n/ui.ts';
import Base from '../../layouts/Base.astro';

const t = UI.fr;
---

<Base lang="fr" title={t.siteTitle} description={t.metaDescription}>
  <p class="demo-banner">{t.demoBanner}</p>

  <main>
    <header class="masthead">
      <h1>{t.heading}</h1>
      <p class="intro">{t.intro}</p>
    </header>

    <TestWizard lang="fr" />
  </main>
</Base>

<style>
  .demo-banner {
    margin: 0;
    padding: 0.5rem 1rem;
    background: var(--ink);
    color: var(--paper);
    font-size: 0.8125rem;
    text-align: center;
    letter-spacing: 0.02em;
  }

  main {
    max-width: 40rem;
    margin: 0 auto;
    padding: 1.5rem 1rem 3rem;
  }

  .masthead {
    padding: 1.5rem 0 2rem;
    border-bottom: 1px solid var(--line);
  }

  h1 {
    margin: 0;
    font-family: Georgia, 'Times New Roman', serif;
    font-size: clamp(1.75rem, 6vw, 2.5rem);
    font-weight: 500;
    line-height: 1.15;
    letter-spacing: -0.01em;
  }

  .intro {
    margin: 0.75rem 0 0;
    color: var(--ink-soft);
    font-size: 0.9375rem;
    max-width: 34rem;
  }

  @media (min-width: 40rem) {
    main {
      padding-top: 2.5rem;
    }
  }
</style>
