{
  "name": "voting-helper",
  "private": true,
  "type": "module",
  "license": "AGPL-3.0-only",
  "workspaces": [
    "data",
    "pipeline",
    "site"
  ],
  "scripts": {
    "build": "npm run build --workspace site",
    "admit:report": "node pipeline/src/commands/admit-report.ts",
    "admit:source": "node pipeline/src/commands/admit-source.ts",
    "extract:positions": "node pipeline/src/commands/extract-positions.ts",
    "link:votes": "node pipeline/src/commands/link-votes.ts",
    "positions:pr": "node pipeline/src/commands/prepare-position-pr.ts",
    "snapshot:programmes": "node pipeline/src/commands/snapshot-programmes.ts",
    "snapshot:verify": "node pipeline/src/commands/snapshot-verify.ts",
    "snapshot:votes": "node pipeline/src/commands/snapshot-votes.ts",
    "statements:pool": "node pipeline/src/commands/statements-pool.ts",
    "statements:select": "node pipeline/src/commands/statements-select.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p data && tsc --noEmit -p pipeline && npm run typecheck --workspace site"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
